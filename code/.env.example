
# ============================================================
# .env.example — Configuration for General Calculator Agent
# Copy this file to .env and fill in the required values.
# Variables marked as (pre-configured) are already set.
# ============================================================

# ══════════════════════════════════════════════════════════
# Agent Identity (PRELOADED)
# ══════════════════════════════════════════════════════════
AGENT_NAME=General Calculator Agent              # Agent name (pre-configured)
AGENT_ID=78b2b0a3-3000-4482-b18d-badf0c0f9c93     # Agent unique identifier (pre-configured)
PROJECT_NAME=19test                                # Project name (pre-configured)
PROJECT_ID=6675d4e6-9f20-4270-8609-43760b6667ff    # Project unique identifier (pre-configured)
USE_KEY_VAULT=false                                # Enable Azure Key Vault integration (set to true for production)
OBS_AZURE_SQL_TRUST_SERVER_CERTIFICATE=yes

# ══════════════════════════════════════════════════════════
# General Configuration
# ══════════════════════════════════════════════════════════
ENVIRONMENT=                         # Deployment environment (e.g., development, production)
VERSION=                             # Application version (informational)
SERVICE_NAME=                         # Service name for observability and logging
SERVICE_VERSION=                      # Service version number
LOG_LEVEL=                            # Logging level (e.g., DEBUG, INFO, WARNING)
CACHE_TTL_SECONDS=                    # Default TTL for result cache (seconds)
DEFAULT_PRECISION=                    # Default numeric precision for calculations (integer)
VALIDATION_CONFIG_PATH=               # Path to validation config file (local path)
SELECTED_DOCUMENT_TITLES=             # Comma-separated or JSON list of doc titles for RAG filtering
LLM_MODELS=                           # JSON array of model pricing/metadata for observability (optional)

# ══════════════════════════════════════════════════════════
# Azure Key Vault
# ══════════════════════════════════════════════════════════
KEY_VAULT_URI=                        # Azure Key Vault URI (e.g., https://your-vault.vault.azure.net/)
AZURE_USE_DEFAULT_CREDENTIAL=         # Use DefaultAzureCredential for Key Vault (true for managed identity, false for service principal)
AZURE_TENANT_ID=                      # Azure AD tenant ID for authentication
AZURE_CLIENT_ID=                      # Azure AD client/application ID
AZURE_CLIENT_SECRET=                  # Azure AD client secret

# ══════════════════════════════════════════════════════════
# Azure Authentication
# ══════════════════════════════════════════════════════════
# (Service principal values above are used only if AZURE_USE_DEFAULT_CREDENTIAL=false)
# The values here are duplicates for clarity in the Azure authentication section.
# They must remain empty when using DefaultAzureCredential in production.
# See AZURE_USE_DEFAULT_CREDENTIAL for toggle.
AZURE_TENANT_ID=                      # Azure AD tenant ID for authentication
AZURE_CLIENT_ID=                      # Azure AD client/application ID
AZURE_CLIENT_SECRET=                  # Azure AD client secret

# ══════════════════════════════════════════════════════════
# LLM Configuration
# ══════════════════════════════════════════════════════════
MODEL_PROVIDER=openai
LLM_MODEL=                            # LLM model name (e.g., gpt-4.1, claude-3-opus)
LLM_TEMPERATURE=                      # Model temperature (0.0-2.0, controls randomness)
LLM_MAX_TOKENS=                       # Maximum tokens in model response
USER_PROMPT_TEMPLATE_ENHANCED=        # System prompt (enhanced) used for LLM system messages
USER_PROMPT_TEMPLATE_OUTPUT_FORMAT=   # Description of the expected output format (for LLM)
USER_PROMPT_TEMPLATE_FALLBACK_RESPONSE= # Fallback response template when computation not possible

# ══════════════════════════════════════════════════════════
# API Keys / Secrets
# ══════════════════════════════════════════════════════════
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
ANTHROPIC_API_KEY=                    # Anthropic API key (if using Anthropic provider)
GOOGLE_API_KEY=                       # Google API key (if using Google provider)
AZURE_CONTENT_SAFETY_KEY=
AZURE_CLIENT_SECRET=                  # Azure AD client secret (service principal, secret)
OBS_AZURE_SQL_PASSWORD=
# Note: Any variable containing API_KEY, SECRET, PASSWORD, or TOKEN belongs here.

# ══════════════════════════════════════════════════════════
# Service Endpoints
# ══════════════════════════════════════════════════════════
AZURE_OPENAI_ENDPOINT=https://kb-openai-01.openai.azure.com/openai/deployments/text-embedding-ada-002/embeddings?api-version=2023-05-15
AZURE_CONTENT_SAFETY_ENDPOINT=https://az-ai-guardrails.cognitiveservices.azure.com/
KEY_VAULT_URI=                         # Azure Key Vault URI (duplicated here for clarity if needed)
AZURE_SEARCH_ENDPOINT=                 # Azure AI Search endpoint URL (for knowledge base / RAG agents)
OBS_AZURE_SQL_SERVER=masgenaisqlserver.database.windows.net
# Endpoints/URLs/Hosts should be set to their full URL/host strings.

# ══════════════════════════════════════════════════════════
# Observability
# ══════════════════════════════════════════════════════════
OBS_DATABASE_TYPE=azure_sql
OBS_AZURE_SQL_SERVER=masgenaisqlserver.database.windows.net
OBS_AZURE_SQL_DATABASE=masgenaisql
OBS_AZURE_SQL_PORT=1433
OBS_AZURE_SQL_USERNAME=saadmin
OBS_AZURE_SQL_PASSWORD=
OBS_AZURE_SQL_SCHEMA=dbo
OBS_AZURE_SQL_TRUST_SERVER_CERTIFICATE=yes

# ══════════════════════════════════════════════════════════
# Agent-Specific
# ══════════════════════════════════════════════════════════
VALIDATION_CONFIG_PATH=                # Path to validation_config.json used by parser/validator
CACHE_TTL_SECONDS=                     # Default cache TTL (seconds) for result cache
DEFAULT_PRECISION=                      # Default number of decimal places to use for computations
SELECTED_DOCUMENT_TITLES=              # Comma-separated or JSON list used for RAG selected titles
LLM_MODELS=                            # JSON list describing LLM models and token pricing (observability)
CONTENT_SAFETY_ENABLED=                # Enable content safety checks (true/false)
CONTENT_SAFETY_SEVERITY_THRESHOLD=     # Severity threshold for content safety (integer)
CONTENT_SAFETY_CHECK_INPUT=            # Whether to check input text with content safety (true/false)
CONTENT_SAFETY_CHECK_OUTPUT=           # Whether to check LLM output with content safety (true/false)
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=api-knowledge
MODEL_PROVIDER=openai
LLM_MODEL=                             # LLM model (repeat for convenience)

# End of .env.example
